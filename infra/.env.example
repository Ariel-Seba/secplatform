# SecPlatform — Environment Variables
# Copy to .env and fill in real values
# Generate secrets with: openssl rand -hex 32

# Database
DB_PASSWORD=changeme_strong_password_here

# Redis
REDIS_PASSWORD=changeme_strong_password_here

# JWT Auth (min 32 chars)
JWT_SECRET=changeme_generate_with_openssl_rand_hex_32

# Internal module auth token
MODULE_SECRET=changeme_generate_with_openssl_rand_hex_32

# Grafana
GRAFANA_PASSWORD=changeme_admin_password

# Domain (for Traefik labels)
DOMAIN=secplatform.local

# Environment
ENVIRONMENT=production
